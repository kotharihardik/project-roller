<div class="entry">
    #set($entryStarCount = $model.getEntryStarCount($entry.id))
    <a class="entryTitle" href="$utils.escapeHTML($entry.permalink)">
        $utils.truncateNicely($utils.removeHTML($entry.title), 50, 50, "...")
    </a><br /> 
    <p class="entryDetails">
        <a href="$utils.escapeHTML($entry.website.URL)">$entry.website.name</a>
        #if($entry.tags.size() > 0) $entry.getTagsAsString() |#end
        #if($entry.category.name)$entry.category.name |#end
        #if($entry.pubTime) $utils.formatDate($entry.pubTime, $text.get("macro.weblog.date.toStringFormat")) |#end
        #if($entry.creator.screenName) By $entry.creator.screenName #end
        #if($utils.isUserAuthenticated())
            |&nbsp;
            #set($starActionStar = $url.action('starAction!star', '/roller-ui/authoring'))
            #set($starActionUnstar = $url.action('starAction!unstar', '/roller-ui/authoring'))
            #set($returnEntry = $utils.getRequest().getRequestURL().toString())
            #set($queryString = $utils.getRequest().getQueryString())
            #if($queryString)
                #set($returnEntry = "${returnEntry}?${queryString}")
            #end
            #set($returnEntry = $utils.encode($returnEntry))
            #if($model.isEntryStarred($entry.id))
                <a href="${starActionUnstar}&targetType=ENTRY&targetId=${entry.id}&returnTo=${returnEntry}">&#9733; Unstar</a> (Stars: $entryStarCount)
            #else
                <a href="${starActionStar}&targetType=ENTRY&targetId=${entry.id}&returnTo=${returnEntry}">&#9734; Star</a> (Stars: $entryStarCount)
            #end
        #else
            | &#9733; Stars: $entryStarCount
        #end
        <br/> 
    </p>
    <p class="entryDescription">                    
        #if($entry.displayContent)
             $utils.truncateNicely($utils.removeHTML($entry.displayContent), 240, 260, "...")
        #else ## planet entries don't have displayContent
             $utils.truncateNicely($utils.removeHTML($entry.text), 240, 260, "...")
        #end
    </p>
</div>
