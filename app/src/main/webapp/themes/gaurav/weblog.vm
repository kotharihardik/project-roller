<!DOCTYPE html>
<html lang="en">
<head>
	#includeTemplate($model.weblog "standard_head")
	<title>$model.weblog.name: $model.weblog.tagline</title>
	#showAutodiscoveryLinks($model.weblog)
	<link rel="stylesheet" href='$url.page("custom.css")' />
    #showAnalyticsTrackingCode($model.weblog)
    #showMetaDescription()
</head>
<body>

	<!-- HEADER -->
	<header>
		#includeTemplate($model.weblog "standard_header")
	</header>

	<!-- BODY -->
	<div class="container">
		
		<div class="row">
			<div class="col-lg-12">
				<h1 class="page-header">$model.weblog.name&nbsp;
				<small>
				#if($model.weblog.tagline)
                    $model.weblog.tagline
                #end
				</small></h1>
			</div>
	  	</div>
	  	
	  	<div class="row">
	  	
		  	<!-- BODY MAIN-->
		   	<div id="main_content" class="col-lg-8">
				#set($pager = $model.getWeblogEntriesPager())
				#showWeblogEntriesPager($pager)
				#if ($model.permalink)
					#showWeblogEntryComments($entry)
					#showWeblogEntryCommentForm($entry)
				#end
				<ul class="pager">
	        		#if($utils.isNotEmpty($pager.prevLink))<li class="previous"><a href="$pager.prevLink">← $pager.prevName</a></li>
#end
				    #if($utils.isNotEmpty($pager.nextLink))<li class="next"><a href="$pager.nextLink">$pager.nextName →</a></li>#end
				</ul>
			</div>
		
			<!-- BODY - SIDEBAR -->
			<div id="sidebar_content" class="col-lg-4">
				<div class="well">
					<h3>Welcome</h3>
					#set($weblogStarCount = $model.getWeblogStarCount($model.weblog.id))
					#if($utils.isUserAuthenticated())
					  #set($starActionStar = $url.action('starAction!star', '/roller-ui/authoring'))
					  #set($starActionUnstar = $url.action('starAction!unstar', '/roller-ui/authoring'))
					  #set($returnHome = $utils.getRequest().getRequestURL().toString())
					  #set($queryString = $utils.getRequest().getQueryString())
					  #if($queryString)
					    #set($returnHome = "${returnHome}?${queryString}")
					  #end
					  #set($returnHome = $utils.encode($returnHome))
					  #if($model.isWeblogStarred($model.weblog.id))
					    <p class="details"><a href="${starActionUnstar}&targetType=WEBLOG&targetId=${model.weblog.id}&returnTo=${returnHome}">&#9733; Unstar this weblog</a> (Stars: $weblogStarCount)</p>
					  #else
					    <p class="details"><a href="${starActionStar}&targetType=WEBLOG&targetId=${model.weblog.id}&returnTo=${returnHome}">&#9734; Star this weblog</a> (Stars: $weblogStarCount)</p>
					  #end
					#else
					  <p class="details">&#9733; Stars: $weblogStarCount</p>
					#end
					<p class="details">
					#set($blurb = $model.weblog.about)
					#if ($blurb)
					$model.weblog.about
					#else
					<span class="setup">Add an about message on your Weblog Settings page and it will appear here</span>
					#end
					Click the link below to subscribe via your favorite feed reader:</p>

					<div id="subscribe">
						<a href="$url.feed.entries.atom">
							<img src='$url.resource("icons/feed-icon-28x28.png")' title="RSS/Atom feed icon" alt="RSS/Atom feed icon" /></a>&nbsp;
						<a href="$url.feed.entries.atom">Subscribe to this blog</a>
					</div>
				</div>
				#if($model)
				<div class="well">
					<h3>Trending Blog Pages</h3>
					<ul>
					#set($trendingWeblogs = $model.getTrendingWeblogs(5))
					#foreach($blog in $trendingWeblogs)
						<li><a href="$url.absoluteSite/$blog.subjectNameShort/">$blog.subjectNameLong</a> [$blog.count]</li>
					#end
					</ul>
					<h3>Trending Blog Posts</h3>
					<ul>
					#set($trendingEntries = $model.getTrendingWeblogEntries(5))
					#foreach($entry in $trendingEntries)
						<li><a href="$url.absoluteSite/$entry.weblogHandle/entry/$entry.subjectNameShort">$entry.subjectNameLong</a> [$entry.count]</li>
					#end
					</ul>
				</div>
				#end
				#if ($mytags && $mytags.size() > 4)
                    <div class="well">
                        #set($mytags = $model.weblog.getPopularTags(-1, 30))
                           <h3>Hot tags</h3>
                           <p class="details">Below are the most often used tags in the blog.
							   Hover over a tag to see a count of entries, click a tag to see
							   the most recent posts with the tag.</p>
                           <div id="tagcloud">
                           #foreach ($tag in $mytags)
                              <a class="tag s${tag.intensity}" href="$url.tag($tag.name)" title="$tag.count">$tag.name</a>
                           #end
                           </div>
				</div>
				#end
			</div> <!-- close sidebar_content -->
		</div> <!-- /.row -->
	</div> <!-- /.container -->

	<!-- FOOTER -->
	<footer>
		#includeTemplate($model.weblog "standard_footer")
	</footer>


</body>
</html>
