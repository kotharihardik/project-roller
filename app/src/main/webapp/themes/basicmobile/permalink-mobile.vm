<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>$model.weblogEntry.title : $model.weblog.name</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <link rel="stylesheet" href="$model.weblog.stylesheet">
  <link rel="stylesheet" href="$url.absoluteSite/roller-ui/styles/jquery.mobile-theme/default.min.css" />
  <link rel="stylesheet" href="$url.absoluteSite/roller-ui/styles/jquery.mobile-theme/jquery.mobile.icons.min.css" />
  <link rel="stylesheet" href="http://code.jquery.com/mobile/1.4.2/jquery.mobile.structure-1.4.2.min.css" />
  #showMetaDescription()
  #showAnalyticsTrackingCode($model.weblog)

  <script src="http://code.jquery.com/jquery-2.1.1.min.js"></script>

  <script>
    $(document).bind("mobileinit", function(){
      $.mobile.ajaxEnabled = false;
    });
  </script>

  <script src="http://code.jquery.com/mobile/1.4.2/jquery.mobile-1.4.2.min.js"></script>
</head>
<!-- permalink-mobile -->
<body>

  <div data-role="page">

    <div data-role="header" data-theme="a">
      <h1>$model.weblogEntry.title : $model.weblog.name</h1>
      ##<a data-rel="back" data-icon="back" data-theme="a">Go back</a>
      <a href=$url.home data-icon="home" data-theme = "a">Weblog</a>
    </div>

    <div role="main" class="ui-content">

      #set($weblogStarCount = $model.getWeblogStarCount($model.weblog.id))
      #if($utils.isUserAuthenticated())
        #set($starActionStar = $url.action('starAction!star', '/roller-ui/authoring'))
        #set($starActionUnstar = $url.action('starAction!unstar', '/roller-ui/authoring'))
        #set($returnHome = $utils.getRequest().getRequestURL().toString())
        #set($queryString = $utils.getRequest().getQueryString())
        #if($queryString)
          #set($returnHome = "${returnHome}?${queryString}")
        #end
        #set($returnHome = $utils.encode($returnHome))
        #if($model.isWeblogStarred($model.weblog.id))
          <p><a href="${starActionUnstar}&targetType=WEBLOG&targetId=${model.weblog.id}&returnTo=${returnHome}">&#9733; Unstar this weblog</a> (Stars: $weblogStarCount)</p>
        #else
          <p><a href="${starActionStar}&targetType=WEBLOG&targetId=${model.weblog.id}&returnTo=${returnHome}">&#9734; Star this weblog</a> (Stars: $weblogStarCount)</p>
        #end
      #else
        <p>&#9733; Stars: $weblogStarCount</p>
      #end

      #set($rootCategory = $model.weblog.getWeblogCategory("nil"))
      #showMobileCategoryLinksList($rootCategory)

      ## show next/previous paging controls
      #set($pager = $model.getWeblogEntriesPager()) 
      <div class="next-previous">
        #showMobileNextPrevEntriesControl($pager)
      </div>

      ## show entry
      #showWeblogEntriesPager($pager)

      ## show comments
      #showMobileWeblogEntryComments($model.weblogEntry)
      
      ## show comment form
      
      <ul data-role="listview" data-divider-theme="b" data-inset="true">
        <li data-role="list-divider">
          Comment
        </li>
        <li data-theme="a">
          #showWeblogEntryCommentForm($model.weblogEntry)
        </li>
      <ul>

      #if($model)
        <ul data-role="listview" data-divider-theme="b" data-inset="true">
          <li data-role="list-divider">Trending Blog Pages</li>
          #set($trendingWeblogs = $model.getTrendingWeblogs(5))
          #foreach($blog in $trendingWeblogs)
            <li data-theme="a"><a href="$url.absoluteSite/$blog.subjectNameShort/">$blog.subjectNameLong ($blog.count)</a></li>
          #end
        </ul>

        <ul data-role="listview" data-divider-theme="b" data-inset="true">
          <li data-role="list-divider">Trending Blog Posts</li>
          #set($trendingEntries = $model.getTrendingWeblogEntries(5))
          #foreach($entry in $trendingEntries)
            <li data-theme="a"><a href="$url.absoluteSite/$entry.weblogHandle/entry/$entry.subjectNameShort">$entry.subjectNameLong ($entry.count)</a></li>
          #end
        </ul>
      #end
    
    </div>

    <div data-role="footer" data-theme="a">
        <h4>Apache Roller Mobile</h4>
    </div>
    
  </div>

<script src="$url.absoluteSite/roller-ui/scripts/translation.js?v=5" defer></script>

<!-- Weblog Q&A Chatbot -->
<link rel="stylesheet" href="$url.absoluteSite/roller-ui/styles/chatbot.css" />
<script>window.ROLLER_CHATBOT_WEBLOG_ID = '$model.weblog.id';</script>
<script>window.ROLLER_CHATBOT_ENTRY_ID = '$model.weblogEntry.id';</script>
<script src="$url.absoluteSite/roller-ui/scripts/chatbot.js?v=1" defer></script>
</body>
</html>