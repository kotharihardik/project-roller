## $model here is a PageModel
## $entry here is a WeblogEntryWrapper
<!-- _day-mobile -->
<ul data-role="listview" data-divider-theme="b" data-inset="true">
  <li data-role="list-divider">$utils.formatDate($day, $text.get("macro.weblog.date.toStringFormat"))</li>
  ## Loop entries
  #foreach( $entry in $entries )
    #set($entryStarCount = $model.getEntryStarCount($entry.id))
    <li data-role="list-divider" data-theme="a">
       <div>
         $entry.title
         #set($commentCount = $entry.commentCount)
         #if($utils.isUserAuthorizedToAuthor($entry.website))
           &nbsp;|&nbsp;&nbsp;<a href="$url.editEntry($entry.anchor)" data-role="button" data-inline="true" data-mini="true">$text.get("generic.edit")</a>
         #end
         #if($entry.commentsStillAllowed || $commentCount > 0)
           |&nbsp;&nbsp;$text.get("macro.weblog.comments") [$commentCount]
         #end
         #if($utils.isUserAuthenticated())
           #set($starActionStar = $url.action('starAction!star', '/roller-ui/authoring'))
           #set($starActionUnstar = $url.action('starAction!unstar', '/roller-ui/authoring'))
           #set($returnEntry = $utils.getRequest().getRequestURL().toString())
           #set($queryString = $utils.getRequest().getQueryString())
           #if($queryString)
             #set($returnEntry = "${returnEntry}?${queryString}")
           #end
           #set($returnEntry = $utils.encode($returnEntry))
           #if($model.isEntryStarred($entry.id))
             |&nbsp;&nbsp;<a href="${starActionUnstar}&targetType=ENTRY&targetId=${entry.id}&returnTo=${returnEntry}">&#9733; Unstar</a> ($entryStarCount)
           #else
             |&nbsp;&nbsp;<a href="${starActionStar}&targetType=ENTRY&targetId=${entry.id}&returnTo=${returnEntry}">&#9734; Star</a> ($entryStarCount)
           #end
         #else
           |&nbsp;&nbsp;&#9733; $entryStarCount
         #end
       </div>
    </li>
    <li data-theme="a">
      #if(!$model.permalink)
        <a href="$entry.permalink" data-transition="slide">
      #end
        <h3>
          #if($utils.isEmpty($entry.text))
            $entry.transformedText
          #else
            $entry.transformedSummary
          #end
        </h3>
        #if($model.permalink)
          <p class="ui-li-desc content-textbox">
            $entry.displayContent
          </p>
        #end
        <p class="ui-li-desc content-textbox">
          Posted at $utils.formatDate($entry.pubTime, $text.get("macro.weblog.datetime.toStringFormat"))
          by $entry.creator.screenName in <span class="category">$entry.category.name</span>
        </p>
      #if(!$model.permalink)
        </a>
      #end
    </li>
  #end ## End for #foreach
</ul>
