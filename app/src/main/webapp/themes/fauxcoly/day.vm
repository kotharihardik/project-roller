#if(!$model.permalink)
<div class="daybox">
    <h4 class="dayTitle">$utils.formatDate($day, $text.get("macro.weblog.date.toStringFormat"))</h4>
#end

    #foreach( $entry in $entries )
    #set($entryStarCount = $model.getEntryStarCount($entry.id))
    <div class="entryBox">
        <a name="$utils.encode($entry.anchor)" id="$utils.encode($entry.anchor)"></a>

        #if($model.permalink)
        <h2 class="entryTitle">$entry.title</h2>
        #else
        <h2 class="entryTitle"><a href="$entry.permalink">$entry.title</a></h2>
        #end

        <div class="entryContent">
            #if($model.permalink)
                $entry.displayContent
            #else
                $entry.displayContent($url.entry($entry.anchor))
            #end
        </div>

        <p class="entryInfo" style="clear: right">
            $entry.creator.screenName in <span class="category">$entry.category.name</span>

            <a class="permalink" href="$url.entry($entry.anchor)">
                $utils.formatDate($entry.pubTime, $text.get("macro.weblog.datetime.toStringFormat"))</a>

            #set($commentCount = $entry.commentCount)
            #if($utils.isUserAuthenticated())
                #set($starActionStar = $url.action('starAction!star', '/roller-ui/authoring'))
                #set($starActionUnstar = $url.action('starAction!unstar', '/roller-ui/authoring'))
                #set($returnEntry = $utils.getRequest().getRequestURL().toString())
                #set($queryString = $utils.getRequest().getQueryString())
                #if($queryString)
                    #set($returnEntry = "${returnEntry}?${queryString}")
                #end
                #set($returnEntry = $utils.encode($returnEntry))
                #if($model.isEntryStarred($entry.id))
                    &nbsp;|&nbsp;
                    <a href="${starActionUnstar}&targetType=ENTRY&targetId=${entry.id}&returnTo=${returnEntry}">&#9733; Unstar</a> (Stars: $entryStarCount)
                #else
                    &nbsp;|&nbsp;
                    <a href="${starActionStar}&targetType=ENTRY&targetId=${entry.id}&returnTo=${returnEntry}">&#9734; Star</a> (Stars: $entryStarCount)
                #end
            #else
                &nbsp;|&nbsp;&#9733; Stars: $entryStarCount
            #end
            #if($entry.commentsStillAllowed || $commentCount > 0)
                #set($link = "$url.comments($entry.anchor)" )
                <a href="$link" class="commentslink">$text.get("macro.weblog.comments") [$commentCount]</a>
            #end

            #if ($utils.isUserAuthorizedToAuthor($entry.website))
                &nbsp;|&nbsp;
                <a href="$url.editEntry($entry.anchor)">
                    $text.get("generic.edit")</a>
            #end
        </p>

        #if ($entry.tags && $entry.tags.size() > 0)
        <p class="entryInfo" style="clear: right">
            Tags:
            #foreach($tag in $entry.tags)
                <a class="tagLink" href="$url.tag($tag.name)">$tag.name</a>
            #end
        </p>
        #end

    </div>
    #end

#if(!$model.permalink)
</div>
#end






